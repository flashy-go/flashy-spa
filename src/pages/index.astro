---
import ContactForm from '../components/ContactForm.jsx';
import { resolveToken } from '../utils/cupons';

export const prerender = false;

const url = new URL(Astro.request.url);
// Production: use opaque token via ?c=TOKEN (for QR codes on flyers)
// Fallback: ?cupon=CODE for direct testing only
const cupon = resolveToken(url.searchParams.get('c')) || url.searchParams.get('cupon') || '';
---

<html class="dark" lang="es-VE">
	<head>
		<meta charset="utf-8"/>
		<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
		<title>Flashy - Puerto Cabello</title>
		<link href="/flashy-logo.jpg?v=3" rel="icon" type="image/jpeg" sizes="any"/>
		<link href="/flashy-logo.jpg?v=3" rel="icon" type="image/jpeg" sizes="32x32"/>
		<link href="/flashy-logo.jpg?v=3" rel="icon" type="image/jpeg" sizes="16x16"/>
		<link href="/flashy-logo.jpg?v=3" rel="apple-touch-icon" sizes="180x180"/>
		<meta content="Flashy - Puerto Cabello" property="og:title"/>
		<meta content="Flashy: Más rápido, más seguro, más tuyo. La revolución del transporte diseñada para la costa carabobeña." property="og:description"/>
		<meta content="/flashy-logo.jpg" property="og:image"/>
		<meta content="website" property="og:type"/>
		<meta content="summary_large_image" name="twitter:card"/>
		<meta content="Flashy - Puerto Cabello" name="twitter:title"/>
		<meta content="Flashy: Más rápido, más seguro, más tuyo. La revolución del transporte diseñada para la costa carabobeña." name="twitter:description"/>
		<meta content="/flashy-logo.jpg" name="twitter:image"/>
		<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;900&family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<script id="tailwind-config">
			tailwind.config = {
				darkMode: "class",
				theme: {
					extend: {
						colors: {
							"surface-tint": "#ff915a",
							"primary-fixed-dim": "#f76600",
							"inverse-primary": "#a24100",
							"surface-dim": "#0c0e0f",
							"surface-variant": "#232628",
							"secondary-fixed-dim": "#cad5ed",
							"primary-fixed": "#ff7a31",
							"on-tertiary-fixed-variant": "#604100",
							"surface-container": "#171a1b",
							"error-dim": "#d53d18",
							"tertiary-fixed-dim": "#efa914",
							"outline": "#747577",
							"tertiary-container": "#ffb627",
							"tertiary-fixed": "#ffb627",
							"on-secondary": "#475266",
							"primary-dim": "#ff7526",
							"surface-container-low": "#111415",
							"on-error-container": "#ffd2c8",
							"surface-container-highest": "#232628",
							"on-secondary-fixed-variant": "#515c70",
							"surface-container-high": "#1d2021",
							"error": "#ff7351",
							"on-secondary-container": "#c5d1e8",
							"on-primary": "#531e00",
							"secondary-container": "#3c475a",
							"primary-container": "#ff7a31",
							"surface-container-lowest": "#000000",
							"on-surface": "#f6f6f7",
							"tertiary-dim": "#efa914",
							"secondary-dim": "#cad5ed",
							"background": "#0c0e0f",
							"outline-variant": "#464849",
							"on-primary-fixed": "#000000",
							"tertiary": "#ffc96f",
							"secondary": "#d8e3fb",
							"secondary-fixed": "#d8e3fb",
							"inverse-surface": "#f9f9fa",
							"on-tertiary-fixed": "#3a2600",
							"on-secondary-fixed": "#354053",
							"on-tertiary": "#614100",
							"error-container": "#b92902",
							"on-error": "#450900",
							"surface-bright": "#292d2e",
							"primary": "#ff915a",
							"on-surface-variant": "#aaabac",
							"surface": "#0c0e0f",
							"on-tertiary-container": "#553900",
							"on-background": "#f6f6f7",
							"inverse-on-surface": "#545556",
							"on-primary-fixed-variant": "#501c00",
							"on-primary-container": "#411500"
						},
						fontFamily: {
							"headline": ["Space Grotesk"],
							"body": ["Manrope"],
							"label": ["Manrope"]
						},
						borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
					},
				},
			}
		</script>
		<style>
			.material-symbols-outlined {
				font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
			}
			.glow-badge {
				box-shadow: 0 0 20px rgba(255, 145, 90, 0.4);
			}
			.bento-card:hover {
				background-color: #232628;
				transform: translateY(-4px);
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}
			@keyframes cupon-entrance {
				from { opacity: 0; transform: translateY(-20px) scale(0.95); }
				to { opacity: 1; transform: translateY(0) scale(1); }
			}
			@keyframes cupon-shimmer {
				0%, 100% { transform: translateX(-100%); }
				50% { transform: translateX(100%); }
			}
			@keyframes cupon-bounce {
				from { transform: scale(1) rotate(-5deg); }
				to { transform: scale(1.15) rotate(5deg); }
			}
		</style>
	</head>
	<body class="bg-background text-on-surface font-body selection:bg-primary/30">
		<!-- TopNavBar -->
		<nav class="fixed top-0 w-full z-50 bg-[#0c0e0f]/80 backdrop-blur-md no-border bg-gradient-to-b from-[#0c0e0f] to-transparent shadow-[0_4px_30px_rgba(255,145,90,0.05)]">
			<div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
				<div class="flex items-center gap-3">
					<img src="/flashy-logo.jpg" alt="Flashy Logo" class="w-8 h-8"/>
					<div class="text-2xl font-black italic tracking-tighter text-[#f6f6f7]">FLASHY</div>
				</div>
				<div class="hidden md:flex items-center gap-8">
					<a class="font-['Space_Grotesk'] tracking-tight text-sm font-bold uppercase text-[#ff915a] border-b-2 border-[#ff915a] pb-1" href="#">Puerto Cabello</a>
					<a class="font-['Space_Grotesk'] tracking-tight text-sm font-bold uppercase text-[#aaabac] hover:text-[#f6f6f7] transition-colors" href="#features">Features</a>
					<a class="font-['Space_Grotesk'] tracking-tight text-sm font-bold uppercase text-[#aaabac] hover:text-[#f6f6f7] transition-colors" href="#waitlist">Waitlist</a>
					<a class="font-['Space_Grotesk'] tracking-tight text-sm font-bold uppercase text-[#aaabac] hover:text-[#f6f6f7] transition-colors" href="/acceso-prioritario">Acceso Prioritario</a>
				</div>
				<a href="/acceso-prioritario" class="bg-gradient-to-br from-primary to-primary-container text-on-primary-fixed font-bold py-1.5 px-2.5 text-[10px] rounded-md uppercase tracking-wider md:py-2.5 md:px-6 md:text-xs md:rounded-lg active:scale-95 transform transition-transform duration-200 hover:opacity-80 animate-pulse">
					Acceso Prioritario
				</a>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="relative min-h-screen flex flex-col items-center justify-center pt-24 pb-16 px-6 overflow-hidden">
			<!-- Radial Background -->
			<div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,_#23170f_0%,_#151718_100%)]"></div>
			<!-- Neon Trail Decoration -->
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-[1px] bg-gradient-to-r from-transparent via-primary to-transparent opacity-20 blur-sm rotate-12"></div>
			<div class="relative z-10 max-w-5xl mx-auto text-center">
				<!-- Floating Badge -->
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container-highest border border-primary/20 glow-badge mb-8">
					<span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">location_on</span>
					<span class="font-['Space_Grotesk'] font-bold text-[10px] tracking-[0.1em] uppercase text-primary">Lanzamiento Exclusivo: Solo en Puerto Cabello</span>
				</div>
				<h1 class="font-headline text-5xl md:text-7xl font-black tracking-tighter text-on-surface mb-6 leading-[1.1] md:leading-[1.05]">
					Puerto Cabello, el futuro de tu <span class="text-primary italic">movilidad</span> llegó.
				</h1>
				<p class="font-body text-xl md:text-2xl text-on-surface-variant max-w-3xl mx-auto mb-12">
					Flashy: Más rápido, más seguro, más tuyo. La revolución del transporte diseñada para la costa carabobeña.
				</p>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a class="w-full sm:w-auto px-10 py-4 bg-gradient-to-br from-primary to-primary-container rounded-lg font-headline font-black text-on-primary text-lg uppercase tracking-widest hover:shadow-[0_0_30px_rgba(255,145,90,0.3)] transition-all" href="#waitlist">
						Únete a la Fase 1
					</a>
					<a class="w-full sm:w-auto px-10 py-4 border border-outline-variant/30 rounded-lg font-headline font-bold text-on-surface text-lg uppercase tracking-widest hover:bg-surface-variant transition-all" href="#features">
						Explorar Features
					</a>
				</div>
			</div>
			<!-- Scroll Indicator -->
			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
				<span class="material-symbols-outlined text-on-surface-variant opacity-40">keyboard_double_arrow_down</span>
			</div>
		</section>

		<!-- Services Section -->
		<section class="py-24 px-6 bg-surface-container-low">
			<div class="max-w-7xl mx-auto">
				<div class="mb-16">
					<h2 class="font-headline text-3xl font-bold uppercase tracking-tight text-on-surface mb-2">Servicios Flashy</h2>
					<div class="w-16 h-1 bg-primary"></div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					<!-- Service 1 -->
					<div class="group relative overflow-hidden rounded-xl bg-surface-container h-[450px]">
						<img class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-110 transition-transform duration-700" data-alt="Close up of a motorcycle engine in dark lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBDm71nrUa2vQRyENWRYZu--_lQbMCJpx-hp7h4AuRfgunf8Ds-mYivVqQE7Ie597u3IGFvt3rPmHLDSwqj9RZZclziFChjetUEFJZW8HR3R6SoUwLEDlqGBOC87sjEEdkd79Mlm4i6JworTMRpkKFBCdNKQnTIORoxkJFONOef5Jv-MjV5bfgqcHid4uBvGotmdDeL0ZD2evvwXSnURup2fBdMXMbuxa2tfKNHcqVbMIyGa5cJedchtAVCQ0vjIxheTFmlWgUvq7I"/>
						<div class="absolute inset-0 bg-gradient-to-t from-surface-container via-surface-container/20 to-transparent"></div>
						<div class="absolute bottom-0 p-8">
							<span class="material-symbols-outlined text-primary text-4xl mb-4">two_wheeler</span>
							<h3 class="font-headline text-2xl font-bold text-on-surface mb-2">Viaje (MotoTaxi)</h3>
							<p class="text-on-surface-variant">Llega a tiempo sin importar el tráfico. La forma más rápida de cruzar la ciudad.</p>
						</div>
					</div>
					<!-- Service 2 -->
					<div class="group relative overflow-hidden rounded-xl bg-surface-container h-[450px]">
						<img class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-110 transition-transform duration-700" data-alt="Courier delivering a package on a bike" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCIaQpS3VmJeD9Yvb3GKy0s0f7O1WZvb32QOQalFPuPj7kHWuovoKrIF5fgXPHBJBOGNAManev_S67488qADKjm2Nlwd_b6imQdTTAjmt1ZhXB-xHhvkgYCeEh1eLHPhbFeAMDHJWKUqz9juyAJ_32iRFYiNTSD9WDuopc8n2Yje_M-TDqfvXCBC5tUlbwu5iMXRBZ7Kfy4UBwt8865YmU-KNC02tQNk6mkRYBaCVdot7ML2dId8tuQHM05K6z_UmE3BLudV-A09NI"/>
						<div class="absolute inset-0 bg-gradient-to-t from-surface-container via-surface-container/20 to-transparent"></div>
						<div class="absolute bottom-0 p-8">
							<span class="material-symbols-outlined text-primary text-4xl mb-4">local_shipping</span>
							<h3 class="font-headline text-2xl font-bold text-on-surface mb-2">Envío (Encomiendas)</h3>
							<p class="text-on-surface-variant">Tus paquetes volando por la ciudad. Seguridad y rapidez en cada entrega.</p>
						</div>
					</div>
					<!-- Service 3 -->
					<div class="group relative overflow-hidden rounded-xl bg-surface-container h-[450px]">
						<img class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-110 transition-transform duration-700" data-alt="Modern delivery concept abstract image" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDfdPhbsA3bEax30tCNIvI-s1YMTri7sePOKwj77TMxZf5_OOtJMbJz4CI7_Yq_MxwVJS3xg4t31LVDtprhpaTHGqMnJLz_nTKEMhkTihG5jcHB4B4NMmKT9Q7ZmC5hO5ALYEL78OlTFrTsmGB4wCwj1zK1mLjEWTtfDfF5U7rbqaloC-wS3aBoeQPRquUJGHS2uhcjxwjT2OD5dwei6vDkA8EbWJHXyr1IsKAJtO5BT0EV5iitUxGO4nyRnV8t6suAyyv979uY7fs"/>
						<div class="absolute inset-0 bg-gradient-to-t from-surface-container via-surface-container/20 to-transparent"></div>
						<div class="absolute bottom-0 p-8">
							<span class="material-symbols-outlined text-primary text-4xl mb-4">shopping_basket</span>
							<h3 class="font-headline text-2xl font-bold text-on-surface mb-2">Lo que sea</h3>
							<p class="text-on-surface-variant">Si cabe en una moto, Flashy lo lleva por ti. Mandados, comida o lo que necesites.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Bento Grid Features -->
		<section class="py-24 px-6 bg-surface overflow-hidden" id="features">
			<div class="max-w-7xl mx-auto">
				<div class="mb-16 text-center md:text-left">
					<h2 class="font-headline text-4xl font-black uppercase tracking-tighter text-on-surface mb-4">10 Killer Features</h2>
					<p class="text-on-surface-variant font-body max-w-xl">La tecnología más avanzada de Venezuela, ahora en tus manos.</p>
				</div>
				<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
					<!-- Card 1: Offline Mode -->
					<div class="bento-card col-span-2 row-span-2 p-8 rounded-xl bg-surface-container border border-outline-variant/10 flex flex-col justify-between">
						<div>
							<span class="material-symbols-outlined text-primary text-5xl mb-6">signal_cellular_off</span>
							<h3 class="font-headline text-2xl font-bold text-on-surface mb-3">Modo Offline (SMS)</h3>
							<p class="text-on-surface-variant text-sm">¿Sin datos? No hay problema. Pide tu Flashy vía SMS con nuestra integración satelital.</p>
						</div>
						<div class="mt-8 text-xs font-black text-primary tracking-widest uppercase">Tecnología Patentada</div>
					</div>
					<!-- Card 2: Multi-Pago Split -->
					<div class="bento-card col-span-2 p-6 rounded-xl bg-surface-container border border-outline-variant/10">
						<span class="material-symbols-outlined text-primary mb-4">account_balance_wallet</span>
						<h3 class="font-headline text-xl font-bold text-on-surface mb-2">Multi-Pago Split</h3>
						<p class="text-on-surface-variant text-xs">No cargues efectivo, divide tu pago con nuestra billetera híbrida y Pago Móvil.</p>
					</div>
					<!-- Card 3: Círculo de Confianza -->
					<div class="bento-card p-6 rounded-xl bg-surface-container border border-outline-variant/10">
						<span class="material-symbols-outlined text-primary mb-4">verified_user</span>
						<h3 class="font-headline text-lg font-bold text-on-surface mb-1 leading-tight">Círculo de Confianza</h3>
						<p class="text-on-surface-variant text-[11px]">Comparte tu ruta en tiempo real con 5 contactos clave.</p>
					</div>
					<!-- Card 4: Taxímetro GPS -->
					<div class="bento-card p-6 rounded-xl bg-surface-container border border-outline-variant/10">
						<span class="material-symbols-outlined text-primary mb-4">speed</span>
						<h3 class="font-headline text-lg font-bold text-on-surface mb-1 leading-tight">Taxímetro GPS</h3>
						<p class="text-on-surface-variant text-[11px]">Precios justos calculados al metro. Sin sorpresas al final.</p>
					</div>
					<!-- Card 5: Subastas -->
					<div class="bento-card col-span-2 p-6 rounded-xl bg-surface-container border border-outline-variant/10 flex items-center gap-6">
						<span class="material-symbols-outlined text-primary text-4xl">gavel</span>
						<div>
							<h3 class="font-headline text-xl font-bold text-on-surface mb-1">Subastas en Vivo</h3>
							<p class="text-on-surface-variant text-xs">Tú propones el precio, los conductores aceptan. El mercado en tus manos.</p>
						</div>
					</div>
					<!-- Card 6: Geofencing -->
					<div class="bento-card p-6 rounded-xl bg-surface-container border border-outline-variant/10">
						<span class="material-symbols-outlined text-primary mb-4">fence</span>
						<h3 class="font-headline text-lg font-bold text-on-surface mb-1 leading-tight">Geofencing</h3>
						<p class="text-on-surface-variant text-[11px]">Zonas de seguridad activa monitoreadas 24/7 en Puerto Cabello.</p>
					</div>
					<!-- Card 7: OTP -->
					<div class="bento-card p-6 rounded-xl bg-surface-container border border-outline-variant/10">
						<span class="material-symbols-outlined text-primary mb-4">password</span>
						<h3 class="font-headline text-lg font-bold text-on-surface mb-1 leading-tight">Validación OTP</h3>
						<p class="text-on-surface-variant text-[11px]">Nunca te subas a la moto equivocada. Código único por viaje.</p>
					</div>
					<!-- Card 8: Recurrentes -->
					<div class="bento-card p-6 rounded-xl bg-surface-container border border-outline-variant/10">
						<span class="material-symbols-outlined text-primary mb-4">event_repeat</span>
						<h3 class="font-headline text-lg font-bold text-on-surface mb-1 leading-tight">Viajes Recurrentes</h3>
						<p class="text-on-surface-variant text-[11px]">Programa tu ida al trabajo o universidad automáticamente.</p>
					</div>
					<!-- Card 9: Waze de Huecos -->
					<div class="bento-card p-6 rounded-xl bg-surface-container border border-outline-variant/10">
						<span class="material-symbols-outlined text-primary mb-4">warning</span>
						<h3 class="font-headline text-lg font-bold text-on-surface mb-1 leading-tight">Waze de Huecos</h3>
						<p class="text-on-surface-variant text-[11px]">Reportes comunitarios de baches para rutas más fluidas.</p>
					</div>
					<!-- Card 10: SOS Mecánico -->
					<div class="bento-card col-span-2 p-6 rounded-xl bg-surface-container border border-outline-variant/10 bg-gradient-to-br from-surface-container to-primary/5">
						<span class="material-symbols-outlined text-primary mb-4">build_circle</span>
						<h3 class="font-headline text-xl font-bold text-on-surface mb-2">SOS Mecánico</h3>
						<p class="text-on-surface-variant text-xs">¿Se accidentó tu moto personal? Pide asistencia o remolque Flashy en segundos.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Pre-registro Form Section -->
		<section class="py-24 px-6 bg-surface-container-low relative overflow-hidden" id="waitlist">
			<div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2"></div>
			<div class="max-w-4xl mx-auto">
				<div class="bg-[#1e293b] border border-[#334155] rounded-2xl p-8 md:p-12 shadow-2xl relative z-10">

					{/* -- Coupon Banner (full width, above columns) -- */}
					{cupon && cupon.toUpperCase() === 'MILHOJASVALENCIA' && (
						<div class="cupon-banner relative overflow-hidden rounded-xl mb-8" style="background: linear-gradient(135deg, #ff6a00 0%, #ff915a 40%, #ffb627 100%); animation: cupon-entrance 0.8s ease-out both 0.5s;">
							<!-- Shimmer overlay -->
							<div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.15) 50%, transparent 100%); animation: cupon-shimmer 2.5s ease-in-out infinite;"></div>

							<div class="relative flex flex-col md:flex-row items-center gap-4 px-6 py-5">
								<!-- Left: emoji + title -->
								<div class="flex items-center gap-3 shrink-0">
									<span class="text-3xl" style="animation: cupon-bounce 1s ease-in-out infinite alternate;">🎉</span>
									<div>
										<h3 class="font-headline font-black text-base md:text-lg text-white uppercase tracking-wide leading-tight drop-shadow-sm">
											¡Cupón de promoción activo!
										</h3>
										<p class="text-white/80 text-xs font-medium mt-0.5">Pre-registro con descuento exclusivo</p>
									</div>
								</div>

								<!-- Center divider (desktop only) -->
								<div class="hidden md:block w-px h-12 bg-white/25 shrink-0"></div>

								<!-- Right: details -->
								<div class="flex-1 flex flex-col sm:flex-row items-center gap-3 text-center md:text-left">
									<div class="flex-1">
										<div class="flex items-center justify-center md:justify-start gap-1.5 mb-1">
											<span class="material-symbols-outlined text-white text-base" style="font-variation-settings: 'FILL' 1;">loyalty</span>
											<span class="font-headline font-black text-white text-xs uppercase tracking-widest">Milhojas Valencia</span>
										</div>
										<p class="text-white/90 text-sm leading-snug">
											¡Gracias por tu fidelidad! Tienes un <strong class="text-white font-black">50% de descuento</strong> en tu próximo viaje con Flashy.
										</p>
