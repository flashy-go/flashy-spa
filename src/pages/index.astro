<style is:global>
  :root {
    --accent:      #FF6A0D;
    --accent-deep: #E8540A;
    --bg:          #0A0A0B;
    --bg-soft:     #111114;
    --ink:         #FAFAF7;
    --muted:       rgba(255,255,255,0.75);
    --border:      rgba(255,255,255,0.08);
    --font-body:   'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-display:'Outfit', sans-serif;
    --font-hero:   'Bebas Neue', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  ::selection { background: var(--accent); color: var(--bg); }

  /* ── Utilities ── */
  .container  { max-width: 1400px; margin: 0 auto; padding: 0 40px; }
  .section    { padding: 80px 0; }
  .border-b   { border-bottom: 1px solid var(--border); }
  .accent     { color: var(--accent); }
  .ink        { color: var(--ink); }
  .italic     { font-style: italic; }
  .muted      { color: var(--muted); }
  .hidden     { display: none !important; }

  /* ── Typography ── */
  .section-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.22em;
    color: var(--accent); margin-bottom: 20px; text-transform: uppercase;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before {
    content: ''; display: inline-block; width: 24px; height: 1px; background: var(--accent);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 72px);
    font-weight: 800; letter-spacing: -0.04em; line-height: 1.02;
  }
  .section-desc { font-size: 17px; color: var(--muted); line-height: 1.65; margin-top: 20px; }
  .section-header { margin-bottom: 64px; max-width: 720px; }

  /* ── Buttons ── */
  .btn-primary {
    background: var(--accent); color: #0A0A0B;
    border: none; cursor: pointer; font-family: var(--font-body);
    font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 10px;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    position: relative; overflow: hidden; border-radius: 6px;
  }
  .btn-primary::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.12), transparent);
    pointer-events: none;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 20px 50px rgba(255,106,13,0.4); background: #FF7A25; }
  .btn-primary:active { transform: translateY(0); }
  .btn-sm  { padding: 12px 22px; font-size: 12px; }
  .btn-lg  { padding: 18px 28px; font-size: 13px; }
  .btn-xl  { padding: 22px 40px; font-size: 15px; }
  .btn-full { padding: 18px 24px; font-size: 13px; width: 100%; justify-content: center; }
  .btn-block {
    display: flex; align-items: center; justify-content: space-between;
    padding: 22px 32px; width: 100%;
    background: var(--accent); color: var(--bg); border: none; cursor: pointer;
    font-family: var(--font-body); font-weight: 800; font-size: 13px;
    letter-spacing: 0.06em; text-transform: uppercase; transition: transform 0.18s, box-shadow 0.18s;
    position: relative; overflow: hidden; border-radius: 6px;
  }
  .btn-block::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.12), transparent);
    pointer-events: none;
  }
  .btn-block:hover { transform: translateY(-2px); box-shadow: 0 20px 50px rgba(255,106,13,0.4); }
  .btn-outline {
    padding: 18px 28px; background: transparent; color: var(--ink);
    border: 1px solid rgba(255,255,255,0.25); font-size: 13px; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer;
    font-family: var(--font-body); transition: all 0.2s; border-radius: 6px;
  }
  .btn-outline:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  /* ── Animations ── */
  @keyframes marquee  { from { transform:translateX(0) } to { transform:translateX(-50%) } }
  @keyframes blink    { 0%,49%{opacity:1} 50%,100%{opacity:0.3} }
  @keyframes speed    { 0%{transform:translateX(-100%);opacity:0} 30%{opacity:1} 100%{transform:translateX(120vw);opacity:0} }
  @keyframes pulse    { 0%,100%{transform:scale(1);opacity:0.4} 50%{transform:scale(1.5);opacity:0} }
  @keyframes fadeUp   { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
  @keyframes phoneFl  { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }

  .blink { animation: blink 1.5s steps(2) infinite; }
  .speedline {
    position: absolute; left: 0; width: 45%; height: 1px; pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(255,106,13,0.5), transparent);
    animation: speed 3s ease-in infinite;
  }

  /* ── Reveal on scroll ── */
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.65s ease, transform 0.65s ease; }
  .reveal.revealed { opacity: 1; transform: translateY(0); }

  /* ── Social Proof ── */
  .social-proof {
    display: inline-flex; align-items: center; gap: 14px;
    padding: 10px 16px; margin-top: 16px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
  }
  .social-proof-avatars { display: flex; }
  .sp-avatar {
    width: 30px; height: 30px; border-radius: 50%; display: flex;
    align-items: center; justify-content: center;
    font-size: 10px; font-weight: 800; color: #0A0A0B;
    margin-left: -8px; border: 2px solid var(--bg);
  }
  .sp-avatar:first-child { margin-left: 0; }
  .sp-avatar:nth-child(1) { background: #FF6A0D; }
  .sp-avatar:nth-child(2) { background: #FFB347; }
  .sp-avatar:nth-child(3) { background: #FF8C42; }
  .sp-avatar:nth-child(4) { background: #E8540A; }
  .social-proof-text { font-size: 13px; color: var(--muted); }
  .social-proof-text strong { color: var(--ink); }

  /* ── Section CTA ── */
  .section-cta {
    margin-top: 40px; padding-top: 28px;
    border-top: 1px dashed rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }
  .section-cta-text {
    font-size: 16px; color: var(--muted);
    line-height: 1.5;
  }

  /* ── Spots Badge ── */
  .spots-badge {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 10px 18px;
    background: rgba(255,106,13,0.08); border: 1px solid rgba(255,106,13,0.2);
    border-radius: 8px; font-size: 14px; color: var(--ink);
  }
  .spots-icon { font-size: 18px; }

  /* ── Final Spots ── */
  .final-spots {
    display: flex; align-items: center; gap: 8px;
    font-size: 15px; color: var(--muted);
    padding: 10px 20px; background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08); border-radius: 8px;
  }
  .final-spots strong { color: var(--ink); }

  /* ── Nav ── */
  #main-nav {
    position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid transparent; transition: all 0.3s;
    padding: 10px 0;
  }
  #main-nav.scrolled {
    background: rgba(10,10,11,0.9);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-color: var(--border);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 18px; padding-bottom: 18px;
  }
  .nav-brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
  .nav-logo-text { font-family: var(--font-display); font-size: 20px; font-weight: 800; letter-spacing: -0.02em; color: var(--ink); }
  .nav-links { display: flex; gap: 36px; font-size: 13px; font-weight: 500; }
  .nav-links a { color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s; letter-spacing: 0.02em; }
  .nav-links a:hover { color: var(--ink); }
  .nav-actions { display: flex; align-items: center; gap: 12px; }

  .nav-hamburger {
    display: none; flex-direction: column; justify-content: center; align-items: center;
    gap: 5px; width: 40px; height: 40px; background: none; border: 1px solid var(--border);
    cursor: pointer; padding: 8px;
  }
  .ham-line {
    display: block; width: 20px; height: 1.5px; background: var(--ink);
    transition: transform 0.3s, opacity 0.3s;
  }
  .nav-hamburger.open .ham-line:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-hamburger.open .ham-line:nth-child(2) { opacity: 0; }
  .nav-hamburger.open .ham-line:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Mobile nav panel */
  .nav-mobile {
    display: none; flex-direction: column; padding: 20px 24px 28px;
    background: rgba(10,10,11,0.97); backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border); position: sticky; top: 57px; z-index: 99;
  }
  .nav-mobile.open { display: flex; }
  .nav-mobile-link {
    color: var(--ink); text-decoration: none; font-size: 22px; font-weight: 700;
    font-family: var(--font-display); letter-spacing: -0.02em;
    padding: 14px 0; border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }
  .nav-mobile-link:hover { color: var(--accent); }
  .nav-mobile-link:last-of-type { border-bottom: none; }

  /* ── Hero ── */
  .hero {
    position: relative; overflow: hidden;
    min-height: calc(100vh - 57px); 
    padding: 0px 0 60px;
    display: flex; align-items: center;
  }
  .hero-grid-bg {
    position: absolute; inset: 0;
    background-image: linear-gradient(var(--border) 1px,transparent 1px), linear-gradient(90deg,var(--border) 1px,transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 75%);
  }
  .hero-glow {
    position: absolute; top: 10%; left: 40%; transform: translateX(-50%);
    width: 900px; height: 900px;
    background: radial-gradient(circle, rgba(255,106,13,0.18), transparent 55%);
    filter: blur(80px); pointer-events: none;
  }
  .hero-inner {
    position: relative; display: grid;
    grid-template-columns: 1.15fr 1fr; gap: 40px; align-items: center; width: 100%;
  }
  .hero-copy { display: flex; flex-direction: column; gap: 0; }

  .badge {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 9px 16px; border: 1px solid rgba(255,106,13,0.35);
    background: rgba(255,106,13,0.06);
    font-size: 10px; font-weight: 700; letter-spacing: 0.18em; color: var(--accent);
    margin-bottom: 16px; width: fit-content;
  }
  .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }

  .hero-title {
    font-family: var(--font-hero);
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.85; letter-spacing: 0.02em; margin: 0 0 20px;
    display: flex; flex-direction: column;
  }
  .hero-title .accent { color: var(--accent); }

  .hero-sub { font-size: clamp(15px, 2vw, 17px); color: var(--muted); line-height: 1.5; max-width: 500px; margin: 0 0 24px; }
  .hero-sub strong { color: var(--ink); font-weight: 600; }

  /* Countdown */
  .countdown {
    display: inline-flex; align-items: stretch;
    background: var(--bg-soft); border: 1px solid var(--border); margin-bottom: 24px;
    border-radius: 8px; overflow: hidden;
  }
  .countdown-label {
    padding: 14px 20px; border-right: 1px solid var(--border);
    display: flex; align-items: center;
    font-size: 11px; font-weight: 800; letter-spacing: 0.22em; color: var(--muted);
    white-space: nowrap;
  }
  .countdown-cell {
    padding: 14px 20px; border-right: 1px solid var(--border);
    text-align: center; min-width: 80px;
  }
  .countdown-cell:last-child { border-right: none; }
  .cd-num {
    display: block; font-family: var(--font-display); font-size: 36px; font-weight: 800;
    color: var(--ink); line-height: 1; letter-spacing: -0.03em;
  }
  .cd-num.accent { color: var(--accent); }
  .cd-lbl { display: block; font-size: 10px; color: var(--muted); letter-spacing: 0.18em; font-weight: 700; margin-top: 6px; }

  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }

  .offer-badge {
    display: inline-flex; align-items: center; gap: 14px;
    padding: 10px 16px; border: 1px dashed rgba(255,106,13,0.45); color: rgba(255,106,13,0.9);
    font-size: 12px; font-weight: 500;
  }
  .offer-tag {
    background: var(--accent); color: var(--bg); padding: 3px 8px;
    font-size: 9px; font-weight: 900; letter-spacing: 0.12em;
  }

  /* Phone mockup */
  .phone-wrap { display: flex; justify-content: center; animation: phoneFl 4s ease-in-out infinite; }
  .phone-shell {
    width: 270px; height: 540px; position: relative;
    background: #0A0A0B; border-radius: 44px; padding: 10px;
    box-shadow:
      0 60px 120px rgba(255,106,13,0.2),
      0 0 0 1px rgba(255,255,255,0.08),
      inset 0 0 0 1px rgba(255,255,255,0.06),
      0 0 80px rgba(255,106,13,0.08);
  }
  .phone-notch {
    position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
    width: 90px; height: 26px; background: #000; border-radius: 13px; z-index: 2;
  }
  .phone-screen { width: 100%; height: 100%; background: #0F0F12; border-radius: 34px; overflow: hidden; position: relative; padding-bottom: 28px; }
  .phone-card {
    position: absolute; left: 0; right: 0; bottom: 0;
    background: rgba(10,10,11,0.97); padding: 18px 16px;
    border-top: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }
  .phone-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
  .phone-label { font-size: 8px; color: var(--muted); letter-spacing: 1.5px; font-weight: 700; }
  .phone-time { font-size: 30px; font-weight: 900; color: var(--ink); line-height: 1; letter-spacing: -0.03em; font-family: var(--font-display); }
  .phone-time-unit { font-size: 14px; color: var(--muted); margin-left: 3px; font-family: var(--font-body); font-weight: 400; }
  .phone-fare { font-size: 22px; font-weight: 800; color: var(--accent); line-height: 1; font-family: var(--font-display); }
  .phone-driver { display: flex; align-items: center; gap: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
  .phone-avatar {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; color: #0A0A0B; font-size: 11px;
  }
  .phone-driver-name { color: var(--ink); font-weight: 700; font-size: 11px; }
  .phone-driver-sub { color: var(--muted); font-size: 9px; }
  .phone-status {
    background: var(--accent); color: #0A0A0B; padding: 5px 9px;
    font-size: 8px; font-weight: 900; letter-spacing: 0.5px; margin-left: auto;
  }

  /* ── Marquee ── */
  .marquee-wrap {
    overflow: hidden; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    padding: 20px 0; background: var(--bg-soft);
  }
  .marquee-track {
    display: flex; gap: 56px; white-space: nowrap;
    animation: marquee 28s linear infinite;
  }
  .marquee-item {
    font-family: var(--font-hero); font-size: 22px; color: var(--ink);
    letter-spacing: 0.04em; display: inline-flex; align-items: center; gap: 20px; flex-shrink: 0;
  }
  .marquee-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); display: inline-block; }

  /* ── Steps ── */
  .steps-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--border);
  }
  .step {
    padding: 44px 36px; border-right: 1px solid var(--border);
    position: relative; transition: background 0.3s;
  }
  .step:last-child { border-right: none; }
  .step:hover { background: rgba(255,106,13,0.03); }
  .step-line { position: absolute; top: 0; left: 0; width: 100%; height: 2px; background: transparent; transition: background 0.3s; }
  .step:hover .step-line { background: var(--accent); }
  .step-num { font-size: 10px; font-weight: 800; color: var(--accent); letter-spacing: 0.22em; margin-bottom: 20px; }
  .step-title { font-family: var(--font-display); font-size: 26px; font-weight: 800; color: var(--ink); margin: 0 0 14px; letter-spacing: -0.02em; line-height: 1.1; }
  .step-desc { font-size: 17px; color: var(--muted); margin: 0; line-height: 1.65; }

  /* ── El Cambio ── */
  .cambio-header { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-bottom: 80px; align-items: end; }
  .cambio-nota { border-left: 2px solid var(--accent); padding-left: 28px; }

  .compare-grid { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid var(--border); }
  .compare-col { padding: 52px 48px; position: relative; }
  .compare-col + .compare-col { border-left: 1px solid var(--border); }
  .compare-col-now { background: linear-gradient(180deg, rgba(255,106,13,0.04), transparent 50%); }
  .compare-meta-l { position: absolute; top: 20px; left: 20px; font-size: 9px; font-weight: 800; letter-spacing: 0.22em; color: var(--muted); }
  .compare-meta-r { position: absolute; top: 20px; right: 20px; font-size: 9px; font-weight: 800; letter-spacing: 0.22em; color: var(--muted); }
  .compare-headline {
    margin-top: 52px; margin-bottom: 28px; padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-display); font-weight: 800; letter-spacing: -0.04em; line-height: 0.95;
  }
  .muted-heavy { color: rgba(255,255,255,0.35); }
  .compare-row {
    display: grid; grid-template-columns: 48px 1fr; gap: 18px;
    padding: 16px 0; border-bottom: 1px dashed rgba(255,255,255,0.08);
  }
  .compare-row-now { grid-template-columns: 48px 1fr auto; border-color: rgba(255,106,13,0.15); }
  .compare-n { font-family: var(--font-display); font-size: 20px; font-weight: 800; color: rgba(255,255,255,0.25); letter-spacing: -0.02em; padding-top: 2px; }
  .compare-step-title { font-size: 18px; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
  .compare-step-desc { font-size: 16px; color: var(--muted); line-height: 1.5; }
  .compare-sec { font-family: var(--font-display); font-size: 13px; font-weight: 700; color: var(--accent); white-space: nowrap; padding-top: 4px; }
  .compare-total { margin-top: 24px; padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.03); }
  .compare-total-now { background: var(--accent); color: var(--bg); }
  .compare-total-label { font-size: 10px; font-weight: 800; letter-spacing: 0.18em; }
  .compare-total-num { font-family: var(--font-display); font-size: 26px; font-weight: 700; letter-spacing: -0.02em; }
  .muted-total .compare-total-label { color: var(--muted); }
  .muted-total .compare-total-num { color: rgba(255,255,255,0.4); }

  .quote-row { display: grid; grid-template-columns: 1.4fr 1fr; gap: 48px; margin-top: 80px; align-items: center; }
  .quote-block { position: relative; padding-left: 52px; }
  .quote-mark {
    position: absolute; left: 0; top: -14px;
    font-family: var(--font-display); font-size: 110px; font-weight: 800; color: var(--accent);
    line-height: 0.7; letter-spacing: -0.05em; font-style: italic;
  }
  .quote-text {
    font-family: var(--font-display); font-size: clamp(22px, 2.4vw, 34px);
    font-weight: 600; color: var(--ink); line-height: 1.25; letter-spacing: -0.02em;
  }

  /* ── Seguridad ── */
  .seg-section { position: relative; overflow: hidden; }
  .seg-glow { position: absolute; inset: 0; background: radial-gradient(ellipse at 25% 50%, rgba(255,106,13,0.09), transparent 60%); pointer-events: none; }
  .seg-grid { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .security-cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-content: start; }
  .security-card { padding: 28px 24px; border: 1px solid var(--border); background: var(--bg); transition: border-color 0.2s; }
  .security-card:hover { border-color: var(--accent); }
  .security-card-check { display: block; color: var(--accent); font-weight: 900; font-size: 22px; margin-bottom: 14px; }
  .security-title { font-weight: 700; color: var(--ink); margin-bottom: 6px; font-size: 15px; }
  .security-desc { font-size: 16px; color: var(--muted); line-height: 1.6; }

  /* ── Roadmap ── */
  .roadmap { position: relative; }
  .roadmap-line { position: absolute; left: 21px; top: 36px; bottom: 36px; width: 1px; background: var(--border); }
  .roadmap-phase { position: relative; padding: 36px 0 36px 64px; }
  .roadmap-dot {
    position: absolute; left: 12px; top: 42px;
    width: 20px; height: 20px; border-radius: 50%;
    background: var(--bg); border: 1px solid rgba(255,255,255,0.2);
  }
  .roadmap-dot-active {
    background: var(--accent); border-color: var(--accent);
    box-shadow: 0 0 0 6px rgba(255,106,13,0.12);
  }
  .roadmap-pulse {
    position: absolute; inset: -10px; border-radius: 50%;
    background: var(--accent); opacity: 0.25; animation: pulse 2.5s infinite;
  }
  .roadmap-meta { display: flex; gap: 16px; align-items: center; margin-bottom: 10px; }
  .roadmap-phase-label { font-size: 10px; font-weight: 800; color: var(--muted); letter-spacing: 0.22em; }
  .roadmap-phase-label.accent { color: var(--accent); }
  .roadmap-status { font-size: 9px; font-weight: 800; padding: 4px 10px; border: 1px solid var(--border); color: var(--muted); letter-spacing: 0.15em; }
  .roadmap-status-active { background: var(--accent); color: #0A0A0B; border: none; }
  .roadmap-title { font-family: var(--font-display); font-size: 30px; font-weight: 800; color: var(--ink); margin: 0 0 16px; letter-spacing: -0.03em; line-height: 1; }
  .roadmap-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .roadmap-tag { padding: 7px 14px; font-size: 12px; font-weight: 600; background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.7); border: 1px solid var(--border); }
  .roadmap-tag-active { background: rgba(255,106,13,0.08); color: var(--accent); border-color: rgba(255,106,13,0.25); }

  /* ── Conductores ── */
