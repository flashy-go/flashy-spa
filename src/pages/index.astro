  <meta property="og:title" content="Flashy — La primera app de mototaxis de Puerto Cabello" />
  <meta property="og:description" content="Pide, súbete, llega. Sin esperas, sin regateos, tarifa clara. Regístrate y obtén 50% OFF en tu primer viaje." />
  <meta property="og:image" content="https://flashygo.com/og-flashy.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Flashy — App de mototaxis en Puerto Cabello, Venezuela" />
  <meta property="og:url" content="https://flashygo.com/flashy" />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_VE" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Flashy — La primera app de mototaxis de Puerto Cabello" />
  <meta name="twitter:description" content="Pide, súbete, llega. Sin esperas, sin regateos, tarifa clara." />
