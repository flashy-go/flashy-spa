---
import UmamiAnalytics from '../components/UmamiAnalytics.astro';

const cuponParam = Astro.url.searchParams.get('cupon');
if (cuponParam) {
  return Astro.redirect(`/cupon/${encodeURIComponent(cuponParam)}`, 302);
}

const registeredCount = import.meta.env.PUBLIC_REGISTERED_COUNT || '300';
const availableSpots = import.meta.env.PUBLIC_AVAILABLE_SPOTS || '700';
---
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Flashy — La primera app de mototaxis de Puerto Cabello</title>
  <meta name="description" content="Pide, súbete, llega. La primera app de mototaxis de Puerto Cabello. Sin esperas, sin regateos, tarifa clara." />
  <link rel="canonical" href="https://flashygo.com/flashy" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="keywords" content="mototaxi Puerto Cabello, app transporte Venezuela, Flashy app, mototaxi Carabobo, transporte urbano Puerto Cabello, pedir mototaxi Venezuela" />
  <meta name="theme-color" content="#FF6A0D" />
  <meta name="geo.region" content="VE-G" />
  <meta name="geo.placename" content="Puerto Cabello, Carabobo, Venezuela" />
