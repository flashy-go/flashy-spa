  <!-- JSON-LD: SoftwareApplication -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Flashy",
    "applicationCategory": "TransportationApplication",
    "applicationSubCategory": "Ridesharing",
    "operatingSystem": "Android, iOS",
    "inLanguage": "es",
    "description": "La primera app de mototaxis de Puerto Cabello. Pide, súbete, llega. Sin esperas, sin regateos, tarifa clara.",
    "url": "https://flashygo.com",
    "datePublished": "2026-05-15",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD",
      "description": "50% de descuento en el primer viaje para los primeros 1.000 registrados"
    },
    "areaServed": {
      "@type": "City",
      "name": "Puerto Cabello",
      "addressCountry": "VE"
    }
  }
  </script>
  <!-- JSON-LD: Organization -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Flashy",
    "url": "https://flashygo.com",
    "logo": "https://flashygo.com/flashy-word-logo.png",
    "email": "contacto@flashygo.com",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "email": "contacto@flashygo.com",
      "availableLanguage": "Spanish"
    },
    "sameAs": [
      "https://instagram.com/flashy.go",
      "https://tiktok.com/@flashy.go"
    ],
    "foundingLocation": {
      "@type": "Place",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Puerto Cabello",
        "addressRegion": "Carabobo",
        "addressCountry": "VE"
      }
    }
  }
  </script>
  <!-- JSON-LD: FAQPage -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuándo está disponible la app Flashy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Flashy se lanza oficialmente el 15 de mayo de 2026 en Puerto Cabello. Si te registras ahora, te avisamos por WhatsApp el día del lanzamiento con el enlace de descarga."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta un viaje con Flashy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La tarifa depende de la distancia, pero siempre la ves antes de confirmar el viaje. Cero regateo, cero sorpresas. Y si te registras antes del lanzamiento, tu primer viaje es 50% más barato."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo verifican a los choferes en Flashy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cada conductor pasa por verificación de cédula, licencia de moto, antecedentes penales y revisión del vehículo. Solo los aprobados manejan en Flashy."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué pasa si tengo una emergencia durante el viaje?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La app tiene un botón de pánico que alerta a soporte y a tus contactos de emergencia. Además puedes compartir tu ruta en vivo con familia para que vean dónde estás."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo se hace el pago en Flashy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le pagas directamente al chofer vía Pago Móvil al llegar. Flashy te conecta — el cobro es entre tú y él, simple y sin vuelto."
        }
      },
      {
        "@type": "Question",
        "name": "Soy mototaxista, ¿cómo me uno a Flashy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Llena el formulario en la página marcando 'Soy mototaxista'. Te contactamos para verificar tus documentos. Los primeros 30 días no cobramos comisión a los conductores fundadores."
        }
      },
      {
        "@type": "Question",
        "name": "¿Flashy llega a otras ciudades de Venezuela?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Empezamos en Puerto Cabello, pero el plan es expandirnos. Si quieres que llegue a tu ciudad, regístrate y déjanos tu zona — nos ayuda a priorizar."
        }
      }
    ]
  }
  </script>
  <!-- Umami Analytics -->
  <UmamiAnalytics />
</head>
