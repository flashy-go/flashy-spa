---
import PriorityAccessForm from '../components/PriorityAccessForm.jsx';
import '../styles/global.css';

export const prerender = false;
---

<html class="dark" lang="es-VE">
	<head>
		<meta charset="utf-8"/>
		<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
		<title>Acceso Prioritario - Flashy</title>
		<meta content="Accede a Flashy antes que nadie. Registra tu correo de Play Store y descarga la app." name="description"/>
		<link href="/flashy-logo.jpg?v=3" rel="icon" type="image/jpeg" sizes="any"/>
		<link href="/flashy-logo.jpg?v=3" rel="icon" type="image/jpeg" sizes="32x32"/>
		<link href="/flashy-logo.jpg?v=3" rel="icon" type="image/jpeg" sizes="16x16"/>
		<link href="/flashy-logo.jpg?v=3" rel="apple-touch-icon" sizes="180x180"/>
		<meta content="Acceso Prioritario - Flashy" property="og:title"/>
		<meta content="Accede a Flashy antes que nadie. Registra tu correo de Play Store y descarga la app." property="og:description"/>
		<meta content="/flashy-logo.jpg" property="og:image"/>
		<meta content="website" property="og:type"/>
		<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;900&family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<script id="tailwind-config">
			tailwind.config = {
				darkMode: "class",
				theme: {
					extend: {
						colors: {
							"surface-tint": "#ff915a",
							"primary-fixed-dim": "#f76600",
							"inverse-primary": "#a24100",
							"surface-dim": "#0c0e0f",
							"surface-variant": "#232628",
							"secondary-fixed-dim": "#cad5ed",
							"primary-fixed": "#ff7a31",
							"on-tertiary-fixed-variant": "#604100",
							"surface-container": "#171a1b",
							"error-dim": "#d53d18",
							"tertiary-fixed-dim": "#efa914",
							"outline": "#747577",
							"tertiary-container": "#ffb627",
							"tertiary-fixed": "#ffb627",
							"on-secondary": "#475266",
							"primary-dim": "#ff7526",
							"surface-container-low": "#111415",
							"on-error-container": "#ffd2c8",
							"surface-container-highest": "#232628",
							"on-secondary-fixed-variant": "#515c70",
							"surface-container-high": "#1d2021",
							"error": "#ff7351",
							"on-secondary-container": "#c5d1e8",
							"on-primary": "#531e00",
							"secondary-container": "#3c475a",
							"primary-container": "#ff7a31",
							"surface-container-lowest": "#000000",
							"on-surface": "#f6f6f7",
							"tertiary-dim": "#efa914",
							"secondary-dim": "#cad5ed",
							"background": "#0c0e0f",
							"outline-variant": "#464849",
							"on-primary-fixed": "#000000",
							"tertiary": "#ffc96f",
							"secondary": "#d8e3fb",
							"secondary-fixed": "#d8e3fb",
							"inverse-surface": "#f9f9fa",
							"on-tertiary-fixed": "#3a2600",
							"on-secondary-fixed": "#354053",
							"on-tertiary": "#614100",
							"error-container": "#b92902",
							"on-error": "#450900",
							"surface-bright": "#292d2e",
							"primary": "#ff915a",
							"on-surface-variant": "#aaabac",
							"surface": "#0c0e0f",
							"on-tertiary-container": "#553900",
							"on-background": "#f6f6f7",
							"inverse-on-surface": "#545556",
							"on-primary-fixed-variant": "#501c00",
							"on-primary-container": "#411500"
						},
						fontFamily: {
							"headline": ["Space Grotesk"],
							"body": ["Manrope"],
							"label": ["Manrope"]
						},
						borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
					},
				},
			}
		</script>
		<style>
			.material-symbols-outlined {
				font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
			}
			.glass-card {
				background: rgba(23, 26, 27, 0.4);
				backdrop-filter: blur(12px);
				border: 1px solid rgba(70, 72, 73, 0.2);
			}
			@keyframes float {
				0%, 100% { transform: translateY(0px); }
				50% { transform: translateY(-8px); }
			}
			@keyframes pulse-glow {
				0%, 100% { box-shadow: 0 0 20px rgba(255, 145, 90, 0.2); }
				50% { box-shadow: 0 0 40px rgba(255, 145, 90, 0.4); }
			}
		</style>
	</head>
	<body class="bg-background text-on-surface font-body selection:bg-primary/30">
		<!-- TopNavBar -->
		<nav class="fixed top-0 w-full z-50 bg-[#0c0e0f]/80 backdrop-blur-md no-border bg-gradient-to-b from-[#0c0e0f] to-transparent shadow-[0_4px_30px_rgba(255,145,90,0.05)]">
			<div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
				<a href="/" class="flex items-center gap-3">
					<img src="/flashy-logo.jpg" alt="Flashy Logo" class="w-8 h-8 rounded-full"/>
					<div class="text-2xl font-black italic tracking-tighter text-[#f6f6f7]">FLASHY</div>
				</a>
				<div class="hidden md:flex items-center gap-8">
					<a class="font-['Space_Grotesk'] tracking-tight text-sm font-bold uppercase text-[#aaabac] hover:text-primary transition-colors" href="/">Inicio</a>
					<a class="font-['Space_Grotesk'] tracking-tight text-sm font-bold uppercase text-[#ff915a] border-b-2 border-[#ff915a] pb-1" href="/acceso-prioritario">Acceso Prioritario</a>
				</div>
				<a href="/acceso-prioritario" class="bg-gradient-to-br from-primary to-primary-container text-on-primary-fixed font-bold py-1.5 px-2.5 text-[10px] rounded-md uppercase tracking-wider md:py-2.5 md:px-6 md:text-xs md:rounded-lg active:scale-95 transform transition-transform duration-200 hover:opacity-80 animate-pulse">
					Acceso Prioritario
				</a>
			</div>
		</nav>

		<main class="relative min-h-screen flex flex-col items-center justify-center pt-28 pb-24 px-6 overflow-hidden">
			<!-- Background Decorations -->
			<div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,_#23170f_0%,_#151718_100%)]"></div>
			<div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/8 blur-[150px] rounded-full pointer-events-none"></div>
			<div class="absolute bottom-0 right-0 w-96 h-96 bg-primary/5 blur-[120px] rounded-full translate-x-1/2 translate-y-1/2 pointer-events-none"></div>

			<div class="relative z-10 max-w-xl mx-auto w-full">
				<!-- Header -->
				<div class="text-center mb-10">
					<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container-highest border border-primary/20 mb-6" style="animation: pulse-glow 3s ease-in-out infinite;">
						<span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
						<span class="font-['Space_Grotesk'] font-bold text-[10px] tracking-[0.1em] uppercase text-primary">Acceso Anticipado</span>
					</div>
					<h1 class="font-headline text-4xl md:text-5xl font-black tracking-tighter text-on-surface mb-4 leading-[1.1]">
						Acceso <span class="text-primary italic">Prioritario</span>
					</h1>
					<p class="text-on-surface-variant text-base md:text-lg max-w-md mx-auto">
						Obtén acceso anticipado a <strong class="text-on-surface">Flashy</strong> y sé de los primeros en experimentar el futuro del transporte.
					</p>
				</div>

				<!-- Form Card -->
				<div class="glass-card rounded-2xl p-6 md:p-8 shadow-2xl" style="animation: pulse-glow 4s ease-in-out infinite;">
					<!-- Phone decoration -->
					<div class="flex justify-center mb-6" style="animation: float 4s ease-in-out infinite;">
						<div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-primary-container flex items-center justify-center shadow-xl shadow-primary/30">
							<span class="material-symbols-outlined text-white text-3xl" style="font-variation-settings: 'FILL' 1;">smartphone</span>
						</div>
					</div>

					<PriorityAccessForm client:load />
				</div>

				<!-- Security note -->
				<div class="mt-6 text-center">
					<div class="inline-flex items-center gap-2 text-on-surface-variant/50">
						<span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">lock</span>
						<span class="text-[10px] uppercase tracking-widest font-bold">Tu información está protegida</span>
					</div>
				</div>
			</div>
		</main>

		<!-- Footer -->
		<footer class="bg-[#0c0e0f] w-full py-12 px-6 border-t border-[#464849]/15">
			<div class="flex flex-col md:flex-row justify-between items-center gap-8 max-w-7xl mx-auto">
				<a href="/" class="flex items-center gap-3 text-lg font-bold text-[#f6f6f7]">
					<img src="/flashy-logo.jpg" alt="Flashy Logo" class="w-6 h-6 rounded-full"/>
					FLASHY
				</a>
				<div class="flex flex-wrap justify-center gap-6">
					<a class="font-['Manrope'] text-[10px] tracking-[0.05em] uppercase text-[#aaabac] hover:text-[#ff915a] transition-colors duration-300" href="/#features">Phase 1 Roadmap</a>
					<a class="font-['Manrope'] text-[10px] tracking-[0.05em] uppercase text-[#aaabac] hover:text-[#ff915a] transition-colors duration-300" href="/politica-de-privacidad">Privacy Policy</a>
					<a class="font-['Manrope'] text-[10px] tracking-[0.05em] uppercase text-[#aaabac] hover:text-[#ff915a] transition-colors duration-300" href="#">Terms of Service</a>
					<a class="font-['Manrope'] text-[10px] tracking-[0.05em] uppercase text-primary font-bold" href="/acceso-prioritario">Acceso Prioritario</a>
				</div>
				<p class="font-['Manrope'] text-[10px] tracking-[0.05em] uppercase text-[#aaabac] text-center md:text-right">
					2024 FLASHY VENEZUELA. KINETIC PRECISION ENGINEERED.
				</p>
			</div>
		</footer>
	</body>
</html>
